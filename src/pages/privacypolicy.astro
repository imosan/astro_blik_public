---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from 'astro:content';
const entry = await getEntry("common", "privacypolicy");
const { Content } = await entry.render();

const pageTitle = "プライバシーポリシー";
const description = "";
---

<BaseLayout pageTitle={pageTitle} description={description}>
    <div class="tenali mx-2 my-4 font-sans font-bold text-4xl">{pageTitle}</div>
    <div class="mx-auto w-full md:w-3/4">
        <Content />
    </div>
</BaseLayout>

<style>
:global(img, p) {
    user-select:none;
    -moz-user-select:none;
    -ms-user-select:none;
    -webkit-user-select:none;
    -khtml-user-select:none;
    -webkit-user-drag: none;
    -khtml-user-drag: none;
    -webkit-touch-callout: none;
}

:global(h2) {
    color: #616161;
    background: #f6f6f6;
    font-family: Arial,Verdana,sans-serif;
    font-size: 1.2rem;
    font-weight: bold;
    letter-spacing: 2px;
    margin: 3rem 0px 3rem 0px;
    padding: 10px 7px 10px 10px;
    border-left: 7px solid #197ebc;
    border-bottom: 1px solid #ababab;
    line-height: 37px; /*高さ*/
    -webkit-border-radius:1px;
    -moz-border-radius:1px;
    border-radius:1px;
}

:global(h3) {
    margin: 1rem 1rem 1rem 1rem;
    padding: 5px 5px 5px 5px;
    color: #616161;
    font-family: Arial,Verdana,sans-serif;
    font-size: 16px;
    font-weight: bold;
    letter-spacing: 2px;
}

:global(h4) {
    margin: 3rem 1rem 3rem 1.4rem;
    padding: 5px 7px 5px 10px;
    color: #616161;
    font-family: Arial,Verdana,sans-serif;
    font-size: 16px;
    font-weight: bold;
    letter-spacing: 2px;
    line-height: 22px;
    -webkit-border-radius:1px;
    -moz-border-radius:1px;
    border-radius:1px;
}

@media (min-width: 0px) {
    :global(p) {
        margin: 0.5rem 0;
        padding: 0.1rem 1rem 0.1rem 1rem;
        font-family: Arial,Verdana,sans-serif;
        font-size: 0.9rem;
    }
    :global(h1) {
        font-family: Arial,Verdana,sans-serif;
        font-size: 1.5rem;
        font-weight: bold;
        letter-spacing: 2px;
        margin: 2rem 0px 2rem 0px;
        padding: 14px 7px 18px 27px;
    }
}

@media (min-width: 800px) {
    :global(p) {
        margin: 0.5rem 0;
        padding: 0.1rem 1rem 0.1rem 1rem;
        font-family: Arial,Verdana,sans-serif;
        font-size: 1rem;
    }
    :global(h1) {
        font-weight: bold;
        letter-spacing: 2px;
        margin-left: 0.5rem/* 8px */;
        margin-right: 0.5rem/* 8px */;
        margin-top: 1rem/* 16px */;
        margin-bottom: 1rem/* 16px */;
        padding: 14px 7px 18px 27px;
        font-size: 2.25rem/* 36px */;
        line-height: 2.5rem/* 40px */;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
    }
}

</style>

<script is:inline>

    document.querySelectorAll("img").forEach((ie) => {
        ie.addEventListener("contextmenu", (e) => {
            e.preventDefault();
        }, false);
        ie.addEventListener("dragstart", (e) => {
            e.preventDefault();
        }, false);
    });

</script>